}
.empty-icon img { width: 100%; height: 100%; object-fit: contain; }
.empty-title { font-size: 20px; font-weight: 600; color: var(--text); }
.empty-sub { font-size: 14px; max-width: 320px; line-height: 1.6; }

.btn-create-first {
  background: linear-gradient(135deg, var(--accent), var(--accent2));
