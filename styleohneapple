@media (max-width: 640px) {
  .auth-box { padding: 32px 24px; margin: 16px; }

  /* Sidebar auf MobilgerÃ¤ten: fest positioniertes Overlay, schiebt nichts weg */
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    height: 100dvh;
    width: 260px !important;
    min-width: 260px !important;
    z-index: 120;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    overflow-x: hidden;
  }
  .sidebar .sidebar-bottom {
    padding-bottom: max(80px, env(safe-area-inset-bottom, 80px));
  }
  .sidebar.open {
    transform: translateX(0);
  }
  /* Sidebar-Grip auf MobilgerÃ¤ten: Startposition links, per JS gesteuert */
  .sidebar-grip {
    left: 0px;
    transition: left 0.3s ease;
  }

  /* Board-Bereich nimmt immer volle Breite â€“ unabhÃ¤ngig von Sidebar-Status */
  .main-layout {
    position: relative;
  }
  .board-area {
    padding: 16px;
    padding-bottom: 100px;
    width: 100%;
  }
  .column { width: 85vw; min-width: 260px; }

  /* Backdrop */
  .sidebar-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    /* Nutzt exakt den Wert, den du oben im :root definiert hast */
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    z-index: 119;
  }
}

/* --- DEZENTER 3D-EFFEKT ------------------------- */
  
:root {
  --highlight-edge: inset 0 1px 1px rgba(255, 255, 255, 0.15);
  --panel-3d: 0 8px 24px rgba(0,0,0,0.3), var(--highlight-edge);
  --card-3d: 0 2px 6px rgba(0,0,0,0.15), var(--highlight-edge);
  --btn-3d: 0 3px 0 rgba(0,0,0,0.3), var(--highlight-edge);
  --btn-3d-active: 0 0 0 rgba(0,0,0,0.3), var(--highlight-edge);
}

body.theme-light {
  --highlight-edge: inset 0 1px 1px rgba(255, 255, 255, 0.8);
  --panel-3d: 0 8px 24px rgba(0,0,0,0.08), var(--highlight-edge);
  --card-3d: 0 2px 6px rgba(0,0,0,0.06), var(--highlight-edge);
  --btn-3d: 0 3px 0 rgba(0,0,0,0.15), var(--highlight-edge);
  --btn-3d-active: 0 0 0 rgba(0,0,0,0.15), var(--highlight-edge);
}

/* 1. Panels & Boxen (Spalten, Auth, Modals, Sidebar) */
.column, .auth-box, .modal, .settings-drawer {
  box-shadow: var(--panel-3d) !important;
}

/* 2. Karten (Cards) */
.card {
  box-shadow: var(--card-3d);
}
.card:hover {
  box-shadow: 0 6px 16px rgba(92,110,248,0.2), var(--highlight-edge);
  transform: translateY(-2px);
}

/* 3. AuffÃ¤llige Buttons (inkl. Klick-Animation) */
.btn, .btn-sm, .btn-google, .btn-create-first, .btn-new-board {
  box-shadow: var(--btn-3d);
  transform: translateY(0);
  transition: transform 0.1s, box-shadow 0.1s, background 0.2s, opacity 0.2s;
}
  
.btn:active, .btn-sm:active, .btn-google:active, .btn-create-first:active, .btn-new-board:active {
  transform: translateY(3px) !important; /* Knopf drÃ¼ckt sich nach unten */
  box-shadow: var(--btn-3d-active) !important; /* Schatten verschwindet beim DrÃ¼cken */
}

/* --- FOOTER ------------------------------------- */
.app-footer-pill {
  pointer-events: all;
  background: rgba(var(--panel-rgb), 0.6);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--border); /* Passt sich dem Theme an */
  border-radius: 20px;
  padding: 5px 16px;
  font-size: 12px;
  white-space: nowrap;
}

.app-footer-link {
  color: var(--text-muted); /* Passt sich dem Theme an */
  cursor: pointer;
  text-decoration: none;
  transition: color 0.2s ease;
}

.app-footer-link:hover {
  color: var(--text); /* Passt sich dem Theme an */
}

/* --- KORREKTUREN FÃœR DEN ADMIN-BEREICH IM LIGHT MODE --- */
body.theme-light .admin-user-btn,
body.theme-light .grade-row,
body.theme-light .user-row,
body.theme-light .admin-board-row {
