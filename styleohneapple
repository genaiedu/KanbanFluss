}

/* --- MOBILE KORREKTUREN FÃœR DEN BOARD-HEADER --- */
@media (max-width: 640px) {
  .board-header {
    flex-direction: row !important;
    flex-wrap: wrap !important;
    justify-content: center !important;
    align-items: center !important;
    gap: 12px !important;
  }
  
  /* Der Titel nimmt die ganze Breite ein und sitzt mittig */
  .board-title-display {
    width: 100%;
    text-align: center;
    margin-bottom: 4px;
  }
  
  /* Der unsichtbare Platzhalter wird auf dem Handy ausgeblendet, 
     damit die runden Buttons schÃ¶n in der Mitte zusammenrÃ¼cken */
  .board-header > div[style*="flex:1"] {
    display: none !important;
  }
  
  /* Zwingt die Buttons dazu, strikt rund zu bleiben */
  .board-header button.btn-circle {
    width: 42px !important;
    height: 42px !important;
    flex-shrink: 0 !important;
    justify-content: center !important;
  }
}

/* --- KREISRUNDE HEADER-BUTTONS MIT BANDEROLE --- */
.btn-circle {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(var(--panel-rgb), var(--panel-opacity, 0.72));
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(100,160,255,0.18);
  color: var(--text);
  cursor: pointer;
  transition: all 0.2s ease;
  position: relative;
  flex-shrink: 0;
}

body.theme-light .btn-circle {
  border-color: var(--border);
  background: #ffffff;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.btn-circle:hover {
  border-color: var(--accent);
  color: var(--accent);
  transform: translateY(-2px);
  box-shadow: 0 6px 12px rgba(92,110,248,0.2);
}

/* Die Banderole (Tooltip) */
.btn-circle::after {
  content: attr(data-tooltip);
  position: absolute;
  bottom: -35px;
  left: 50%;
  transform: translateX(-50%) translateY(10px);
  background: var(--surface2);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  color: var(--text);
  padding: 6px 12px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  white-space: nowrap;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
  pointer-events: none;
  z-index: 1000;
}

.btn-circle:hover::after {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(0);
}

/* Klick-Effekt fÃ¼r den Board-Titel */
.board-title-display {
  cursor: pointer;
  transition: all 0.2s;
}
.board-title-display:hover {
  border-color: var(--accent);
  background: rgba(92,110,248,0.1);
}
.title-edit-icon {
  width: 16px;
  height: 16px;
